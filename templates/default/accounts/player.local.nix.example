# Sample: operator-local identity for `player`. Copy to
# `accounts/player.local.nix` (gitignored) and fill in your own values.
#
# The framework reads these slots from `myOS.users.<name>.identity.*`:
#
#   identity.git.name                      git user.name
#   identity.git.email                     git user.email
#   identity.audio.micSourceAlias          pactl source= for `echo_mic`
#   identity.audio.micLoopbackSink         pactl sink=   for `echo_mic`  (optional)
#   identity.workspace.autoUpdateRepoPath  path consumed by modules/desktop/auto-update.nix
#
# Any slot you leave unset is treated as "not configured" — e.g. git
# user.name is simply not set if you omit `identity.git.name`, and
# `echo_mic` is not emitted if `identity.audio.micSourceAlias` is null.
{ ... }:
{
  myOS.users.player.identity = {
    git.name  = "Ada Lovelace";
    git.email = "ada@example.com";

    # Run `pactl list short sources` to find the source name.
    audio.micSourceAlias = "alsa_input.usb-XXXX_MyMic-00.mono-fallback";
    # Optional: pin the monitor sink.
    # audio.micLoopbackSink = "alsa_output.pci-0000_00_00.0.analog-stereo";
  };
}
